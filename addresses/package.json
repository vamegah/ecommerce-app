    "brace-expansion": "^1.1.13",
    "postcss": "^8.5.10",
    "rollup": "^4.59.0",
    "esbuild": "^0.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^4.1.8",
    "fast-check": "^3.15.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.8"
