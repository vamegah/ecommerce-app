{
  "name": "multi-address-management",
  "version": "1.0.0",
  "description": "Multi-address management system for e-commerce platform",
  "main": "index.js",
  "scripts": {
    "test": "node run-vitest.js",
    "test:watch": "node run-vitest.js --config vitest.config.js",
    "test:coverage": "node run-vitest.js --coverage --config vitest.config.js",
    "build": "tsc",
    "type-check": "tsc --noEmit"
