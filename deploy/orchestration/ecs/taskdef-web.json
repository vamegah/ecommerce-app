{
  "family": "greatkart-web",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::<account-id>:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::<account-id>:role/greatkartTaskRole",
  "containerDefinitions": [
    {
      "name": "web",
      "image": "ghcr.io/<owner>/<repo>/greatkart-web:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "DJANGO_SETTINGS_MODULE", "value": "greatkartecommerce.settings" },
        { "name": "DJANGO_CONFIGURATION", "value": "Prod" },
        { "name": "DB_ENGINE", "value": "postgres" },
        { "name": "CACHE_BACKEND", "value": "redis" },
        { "name": "POSTGRES_SSLMODE", "value": "require" }
      ],
      "secrets": [
        { "name": "SECRET_KEY", "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:greatkart/secret-key" },
        { "name": "POSTGRES_DB", "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:greatkart/postgres-db" },
        { "name": "POSTGRES_USER", "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:greatkart/postgres-user" },
        { "name": "POSTGRES_PASSWORD", "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:greatkart/postgres-password" },
        { "name": "POSTGRES_HOST", "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:greatkart/postgres-host" },
        { "name": "REDIS_URL", "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:greatkart/redis-url" }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -fsS http://localhost:8000/healthz/ || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 45
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/greatkart/web",
          "awslogs-region": "<region>",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
